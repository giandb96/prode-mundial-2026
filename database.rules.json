{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'gian96db@gmail.com')"
      }
    },
    "picks": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.token.email === 'gian96db@gmail.com'",
        "champion": {
          ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'gian96db@gmail.com')"
        },
        "topScorer": {
          ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'gian96db@gmail.com')"
        },
        "lastUpdate": {
          ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'gian96db@gmail.com')"
        },
        "matches": {
          "$matchId": {
            ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'gian96db@gmail.com') && !root.child('tournament').child('results').child($matchId).exists()"
          }
        }
      }
    },
    "tournament": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email === 'gian96db@gmail.com'"
    }
  }
}
